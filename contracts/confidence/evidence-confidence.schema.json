{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fool-platform.dev/schemas/confidence/evidence-confidence.schema.json",
  "title": "EvidenceConfidence",
  "description": "A confidence assessment scoped to a single Evidence object, capturing how strongly the evidence's content is trusted independent of the reliability of the Source that produced it. Referenced by contracts/domain/evidence.schema.json#/properties/confidence.",
  "type": "object",
  "required": ["score", "level", "method", "assessed_at", "evidence_ref"],
  "properties": {
    "score": { "$ref": "../common/common-defs.schema.json#/$defs/confidenceScore" },
    "level": { "$ref": "../common/common-defs.schema.json#/$defs/confidenceLevel" },
    "rationale": { "type": "string" },
    "method": { "type": "string" },
    "assessed_by": { "type": "string" },
    "assessed_at": { "$ref": "../common/common-defs.schema.json#/$defs/timestamp" },
    "evidence_refs": { "$ref": "../common/common-defs.schema.json#/$defs/referenceList" },
    "source_refs": { "$ref": "../common/common-defs.schema.json#/$defs/referenceList" },
    "evidence_ref": { "$ref": "../common/common-defs.schema.json#/$defs/reference" },
    "integrity_verified": {
      "type": "boolean",
      "description": "Whether the evidence's content_hash has been verified against its stored artifact."
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "score": 0.95,
      "level": "very_high",
      "method": "direct_observation",
      "assessed_at": "2026-07-15T09:00:00Z",
      "evidence_refs": [],
      "source_refs": [],
      "evidence_ref": { "ref_id": "4d5e6f7a-8b9c-4d1e-9f0a-1b2c3d4e5f6a", "ref_type": "evidence" },
      "integrity_verified": true
    }
  ]
}
