{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fool-platform.dev/schemas/domain/evidence.schema.json",
  "title": "Evidence",
  "description": "Evidence is a discrete, provenance-bearing artifact (document, screenshot, dataset row, message, transaction record, etc.) collected from a Source in support of an Identity, Entity, Relationship, or Finding. Evidence is the atomic unit of proof in the platform; nothing may be asserted without at least one evidence or source reference.",
  "type": "object",
  "required": ["id", "version", "created_at", "updated_at", "status", "evidence_type", "collected_at", "source_ref"],
  "properties": {
    "id": { "$ref": "../common/common-defs.schema.json#/$defs/id" },
    "version": { "$ref": "../common/common-defs.schema.json#/$defs/semanticVersion" },
    "created_at": { "$ref": "../common/common-defs.schema.json#/$defs/timestamp" },
    "updated_at": { "$ref": "../common/common-defs.schema.json#/$defs/timestamp" },
    "status": { "$ref": "../common/common-defs.schema.json#/$defs/status" },
    "classification": { "$ref": "../common/common-defs.schema.json#/$defs/classificationLevel" },
    "evidence_type": {
      "type": "string",
      "enum": ["document", "screenshot", "dataset_record", "message", "transaction", "media", "log_entry", "other"]
    },
    "description": { "type": "string" },
    "content_ref": {
      "type": "string",
      "format": "uri",
      "description": "URI pointing to the stored evidence artifact. This phase defines the field only; no storage engine is implemented."
    },
    "content_hash": {
      "type": "string",
      "description": "Cryptographic hash of the evidence content, used for integrity verification and chain of custody."
    },
    "collected_at": { "$ref": "../common/common-defs.schema.json#/$defs/timestamp" },
    "source_ref": { "$ref": "../common/common-defs.schema.json#/$defs/reference" },
    "identity_refs": { "$ref": "../common/common-defs.schema.json#/$defs/referenceList" },
    "entity_refs": { "$ref": "../common/common-defs.schema.json#/$defs/referenceList" },
    "chain_of_custody_refs": { "$ref": "../common/common-defs.schema.json#/$defs/referenceList" },
    "confidence": { "$ref": "../common/common-defs.schema.json#/$defs/confidenceRef" },
    "provenance": { "$ref": "../common/common-defs.schema.json#/$defs/provenance" },
    "tags": { "$ref": "../common/common-defs.schema.json#/$defs/tags" },
    "metadata": { "$ref": "../common/common-defs.schema.json#/$defs/metadata" }
  },
  "additionalProperties": false,
  "examples": [
    {
      "id": "4d5e6f7a-8b9c-4d1e-9f0a-1b2c3d4e5f6a",
      "version": "1.0.0",
      "created_at": "2026-07-15T09:00:00Z",
      "updated_at": "2026-07-15T09:00:00Z",
      "status": "active",
      "classification": "restricted",
      "evidence_type": "document",
      "description": "Public business registry extract",
      "content_ref": "https://evidence.fool-platform.dev/artifacts/4d5e6f7a.pdf",
      "content_hash": "sha256:9f86d081884c7d659a2feaa0c55ad015a3bf4f1b2b0b822cd15d6c15b0f00a08",
      "collected_at": "2026-07-15T08:30:00Z",
      "source_ref": { "ref_id": "0c9b6f2a-4e6a-4a1a-9a8a-8f6c2b1d3e44", "ref_type": "source" },
      "identity_refs": [{ "ref_id": "b7e2b3d0-5c3f-4a9e-9b8b-2e7f1a6c9d10", "ref_type": "identity" }],
      "entity_refs": [],
      "chain_of_custody_refs": [],
      "confidence": {
        "score": 0.95,
        "level": "very_high",
        "method": "direct_observation",
        "assessed_at": "2026-07-15T09:00:00Z"
      },
      "provenance": {
        "origin": "research-agent",
        "recorded_at": "2026-07-15T08:30:00Z"
      },
      "tags": ["registry"],
      "metadata": {}
    }
  ]
}
