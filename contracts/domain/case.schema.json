{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fool-platform.dev/schemas/domain/case.schema.json",
  "title": "Case",
  "description": "A Case is the top-level administrative and accountability container for platform work. A Case may hold one or more Investigations, has an owning human accountable for it, and represents the unit at which access control, retention, and reporting are ultimately organized.",
  "type": "object",
  "required": ["id", "version", "created_at", "updated_at", "status", "title", "opened_at", "owner"],
  "properties": {
    "id": { "$ref": "../common/common-defs.schema.json#/$defs/id" },
    "version": { "$ref": "../common/common-defs.schema.json#/$defs/semanticVersion" },
    "created_at": { "$ref": "../common/common-defs.schema.json#/$defs/timestamp" },
    "updated_at": { "$ref": "../common/common-defs.schema.json#/$defs/timestamp" },
    "status": { "$ref": "../common/common-defs.schema.json#/$defs/status" },
    "classification": { "$ref": "../common/common-defs.schema.json#/$defs/classificationLevel" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "priority": {
      "type": "string",
      "enum": ["low", "normal", "high", "critical"]
    },
    "owner": {
      "type": "string",
      "minLength": 1,
      "description": "Accountable human owner of this case. The platform never removes human accountability from case ownership."
    },
    "opened_at": { "$ref": "../common/common-defs.schema.json#/$defs/timestamp" },
    "closed_at": { "$ref": "../common/common-defs.schema.json#/$defs/timestamp" },
    "identity_refs": { "$ref": "../common/common-defs.schema.json#/$defs/referenceList" },
    "investigation_refs": { "$ref": "../common/common-defs.schema.json#/$defs/referenceList" },
    "provenance": { "$ref": "../common/common-defs.schema.json#/$defs/provenance" },
    "tags": { "$ref": "../common/common-defs.schema.json#/$defs/tags" },
    "metadata": { "$ref": "../common/common-defs.schema.json#/$defs/metadata" }
  },
  "additionalProperties": false,
  "examples": [
    {
      "id": "5e6f7a8b-9c0d-4e1f-9a0b-1c2d3e4f5a6b",
      "version": "1.0.0",
      "created_at": "2026-07-15T07:00:00Z",
      "updated_at": "2026-07-15T07:00:00Z",
      "status": "active",
      "classification": "confidential",
      "title": "Case-2026-0142",
      "description": "Fraud-pattern investigation opened from an inbound tip.",
      "priority": "high",
      "owner": "analyst.lead@fool-platform.dev",
      "opened_at": "2026-07-15T07:00:00Z",
      "identity_refs": [],
      "investigation_refs": [],
      "provenance": {
        "origin": "case-intake",
        "recorded_at": "2026-07-15T07:00:00Z"
      },
      "tags": ["fraud"],
      "metadata": {}
    }
  ]
}
