{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fool-platform.dev/schemas/agent/agent-event.schema.json",
  "title": "AgentEvent",
  "description": "An event emitted by an agent during task execution, per the Event-Driven Language principle. Events are the official, versionable language agents use to communicate task lifecycle transitions; they are contracts, not implementation details.",
  "type": "object",
  "required": ["event_id", "event_type", "task_id", "agent_id", "occurred_at", "version"],
  "properties": {
    "event_id": { "$ref": "../common/common-defs.schema.json#/$defs/id" },
    "event_type": {
      "type": "string",
      "enum": [
        "agent.task.assigned",
        "agent.task.started",
        "agent.task.progress",
        "agent.task.completed",
        "agent.task.failed",
        "agent.task.cancelled"
      ]
    },
    "version": { "$ref": "../common/common-defs.schema.json#/$defs/semanticVersion" },
    "task_id": { "$ref": "../common/common-defs.schema.json#/$defs/id" },
    "agent_id": { "$ref": "../common/common-defs.schema.json#/$defs/dottedIdentifier" },
    "trace_id": { "$ref": "../common/common-defs.schema.json#/$defs/id" },
    "payload": {
      "type": "object",
      "description": "Event-type-specific payload.",
      "additionalProperties": true
    },
    "occurred_at": { "$ref": "../common/common-defs.schema.json#/$defs/timestamp" },
    "metadata": { "$ref": "../common/common-defs.schema.json#/$defs/metadata" }
  },
  "additionalProperties": false,
  "examples": [
    {
      "event_id": "d4e5f6a7-b8c9-4d1e-9f0a-1b2c3d4e5f6a",
      "event_type": "agent.task.completed",
      "version": "1.0.0",
      "task_id": "8b9c0d1e-2f3a-4b4c-9d0e-1f2a3b4c5d6e",
      "agent_id": "agent.research.v1",
      "trace_id": "9c0d1e2f-3a4b-4c5d-9e0f-1a2b3c4d5e6f",
      "payload": { "result_id": "c3d4e5f6-a7b8-4c1d-9e0f-1a2b3c4d5e6f" },
      "occurred_at": "2026-07-15T09:12:00Z",
      "metadata": {}
    }
  ]
}
