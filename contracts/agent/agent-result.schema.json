{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fool-platform.dev/schemas/agent/agent-result.schema.json",
  "title": "AgentResult",
  "description": "The outcome of an AgentTask: the produced outputs, confidence in those outputs, and any errors encountered. Every AgentResult references the task_id it completes, closing the request/response contract between the workflow layer and the agent.",
  "type": "object",
  "required": ["result_id", "task_id", "agent_id", "status", "completed_at"],
  "properties": {
    "result_id": { "$ref": "../common/common-defs.schema.json#/$defs/id" },
    "task_id": { "$ref": "../common/common-defs.schema.json#/$defs/id" },
    "agent_id": { "$ref": "../common/common-defs.schema.json#/$defs/dottedIdentifier" },
    "status": {
      "type": "string",
      "enum": ["completed", "failed", "partial", "cancelled"]
    },
    "outputs": {
      "type": "object",
      "description": "Result-specific output payload, shaped by the agent's declared output contracts.",
      "additionalProperties": true
    },
    "produced_refs": {
      "$ref": "../common/common-defs.schema.json#/$defs/referenceList",
      "description": "References to domain objects (Entity, Evidence, Finding, etc.) produced or updated by this result."
    },
    "confidence": { "$ref": "../common/common-defs.schema.json#/$defs/confidenceRef" },
    "errors": {
      "type": "array",
      "items": { "$ref": "agent-error.schema.json" }
    },
    "trace_id": { "$ref": "../common/common-defs.schema.json#/$defs/id" },
    "started_at": { "$ref": "../common/common-defs.schema.json#/$defs/timestamp" },
    "completed_at": { "$ref": "../common/common-defs.schema.json#/$defs/timestamp" },
    "metadata": { "$ref": "../common/common-defs.schema.json#/$defs/metadata" }
  },
  "additionalProperties": false,
  "examples": [
    {
      "result_id": "c3d4e5f6-a7b8-4c1d-9e0f-1a2b3c4d5e6f",
      "task_id": "8b9c0d1e-2f3a-4b4c-9d0e-1f2a3b4c5d6e",
      "agent_id": "agent.research.v1",
      "status": "completed",
      "outputs": { "candidate_sources": 5 },
      "produced_refs": [],
      "confidence": {
        "score": 0.7,
        "level": "moderate",
        "method": "source_enumeration",
        "assessed_at": "2026-07-15T09:12:00Z"
      },
      "errors": [],
      "trace_id": "9c0d1e2f-3a4b-4c5d-9e0f-1a2b3c4d5e6f",
      "started_at": "2026-07-15T09:05:10Z",
      "completed_at": "2026-07-15T09:12:00Z",
      "metadata": {}
    }
  ]
}
